{
  "name": "grammy",
  "version": "1.3.2",
  "description": "Телеграм-бот для сохранения показаний коммунальных услуг.",
  "main": "dist/index.js",
  "type": "module",
  "homepage": "https://grammy.driz.pp.ua/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DriZ/Grammy.git"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "docs": "typedoc",
    "start": "npm run build && node -r dotenv/config dist/index.js",
    "dev": "tsx -r dotenv/config index.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "release": "standard-version",
    "migrate": "tsx -r dotenv/config scripts/migrateAccounts.ts",
    "restore": "tsx -r dotenv/config scripts/restoreDatabase.ts",
    "check-locales": "tsx scripts/checkLocales.ts"
  },
  "author": "DriZ",
  "license": "MIT",
  "dependencies": {
    "@grammyjs/hydrate": "^1.6.0",
    "@grammyjs/i18n": "^1.1.2",
    "dotenv": "^17.2.3",
    "geo-tz": "^8.1.5",
    "glob": "^13.0.5",
    "grammy": "^1.40.0",
    "mongoose": "^9.1.6",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  }
}
